{
	# We bring our own certs for local enterprise verification.
	auto_https off
}

http://localhost, http://127.0.0.1 {
	redir https://{host}{uri} permanent
}

https://localhost, https://127.0.0.1 {
	tls /etc/caddy/pki/localhost.crt /etc/caddy/pki/localhost.key {
		protocols tls1.2 tls1.3
	}

	encode zstd gzip

	header {
		# Security headers (baseline for enterprise deployments)
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
		-Server
	}

	@api path /api/* /health /metrics /docs* /swagger* /redoc*
	reverse_proxy @api https://api-mtls:3443 {
		header_up Host api-mtls

		transport http {
			tls
			tls_server_name api-mtls
			tls_trust_pool file /etc/caddy/pki/ca.crt
			tls_client_auth /etc/caddy/pki/gateway-client.crt /etc/caddy/pki/gateway-client.key
		}
	}

	reverse_proxy web:8849
}
