FROM mcr.microsoft.com/devcontainers/javascript-node:22@sha256:b5eeec8d65d42328b885022935fc790d439e1882b77352cf8a4c8d5831d871e6 AS deps

WORKDIR /app

ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

RUN corepack enable && corepack prepare pnpm@9.1.0 --activate

COPY apps/web/package.json apps/web/pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile


FROM mcr.microsoft.com/devcontainers/javascript-node:22@sha256:b5eeec8d65d42328b885022935fc790d439e1882b77352cf8a4c8d5831d871e6 AS build

WORKDIR /app

ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

RUN corepack enable && corepack prepare pnpm@9.1.0 --activate

COPY --from=deps /app/node_modules ./node_modules
COPY apps/web ./
RUN mkdir -p public

ARG LAW_EYE_API_PROXY_TARGET=http://api:3001

ENV NEXT_TELEMETRY_DISABLED=1
ENV NEXT_PUBLIC_API_URL=
ENV LAW_EYE_API_PROXY_TARGET=$LAW_EYE_API_PROXY_TARGET
RUN pnpm build
RUN pnpm prune --prod


FROM mcr.microsoft.com/devcontainers/javascript-node:22@sha256:b5eeec8d65d42328b885022935fc790d439e1882b77352cf8a4c8d5831d871e6 AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

COPY --from=build /app/.next ./.next
COPY --from=build /app/public ./public
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/package.json ./package.json

USER node

EXPOSE 8849

CMD ["node", "./node_modules/next/dist/bin/next", "start", "-p", "8849"]
