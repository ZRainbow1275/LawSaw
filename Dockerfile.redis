FROM mcr.microsoft.com/devcontainers/base:ubuntu@sha256:3dcb059253b2ebb44de3936620e1cff3dadcd2c1c982d579081ca8128c1eb319

ARG DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
  && apt-get install -y redis-server \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /data

USER 1000:1000

EXPOSE 6379

CMD ["sh", "-c", "test -n \"$REDIS_PASSWORD\" || { echo \"REDIS_PASSWORD is required\" >&2; exit 1; }; exec redis-server --appendonly yes --protected-mode yes --bind 0.0.0.0 --port 6379 --requirepass \"$REDIS_PASSWORD\" --maxmemory ${REDIS_MAXMEMORY:-256mb} --maxmemory-policy allkeys-lru"]
