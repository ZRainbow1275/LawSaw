# Docker Compose 必需环境变量
# ⚠️ 不要在仓库目录（workspace）创建/保存 `.env`：gitignore 不是控制措施。
# 推荐做法：
# - 本地无 DockerHub 运行：直接执行 `scripts/no-dockerhub/start-stack.sh`（默认在用户 state 目录生成 `secrets.env`）
# - 直接使用 compose：用 `docker compose --env-file <外部路径>` 指向本文件的副本（副本放在用户 state 目录）
POSTGRES_PASSWORD=
REDIS_PASSWORD=
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=

# 可选：端口映射（用于避免本机端口冲突）
# POSTGRES_HOST_PORT=5435
# REDIS_HOST_PORT=6380
# API_HOST_PORT=3001
# WEB_HOST_PORT=8849
# MINIO_API_PORT=9000
# MINIO_CONSOLE_PORT=9001
# N8N_HOST_PORT=5678

# AI（OpenAI compatible）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Web Push（浏览器推送）
# - 需配置 VAPID key pair（base64url/base64 编码的原始 key bytes）
# - subject 建议使用 `mailto:` 或 https URL（将写入 VAPID JWT 的 `sub`）
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_SUBJECT=

# n8n workflows（可选）
EMAIL_FROM=noreply@laweye.com
EMAIL_TO=

# 生产模式（启用 secure cookie）
# PRODUCTION=true

# Auth（可选）
# - TTL 仅影响 token 过期时间；生产环境应通过邮件等渠道交付 token（API 不会回传 raw token）
# LAW_EYE__AUTH__PASSWORD_RESET_TTL_SECONDS=3600
# LAW_EYE__AUTH__EMAIL_VERIFICATION_TTL_SECONDS=86400

# Rate limit（可选，按客户端 IP）
# LAW_EYE__RATE_LIMIT__LOGIN_MAX_REQUESTS=5
# LAW_EYE__RATE_LIMIT__LOGIN_WINDOW_SECONDS=900
# LAW_EYE__RATE_LIMIT__REGISTER_MAX_REQUESTS=3
# LAW_EYE__RATE_LIMIT__REGISTER_WINDOW_SECONDS=3600
# LAW_EYE__RATE_LIMIT__PASSWORD_RESET_MAX_REQUESTS=3
# LAW_EYE__RATE_LIMIT__PASSWORD_RESET_WINDOW_SECONDS=3600
# LAW_EYE__RATE_LIMIT__EMAIL_VERIFICATION_MAX_REQUESTS=5
# LAW_EYE__RATE_LIMIT__EMAIL_VERIFICATION_WINDOW_SECONDS=3600
# LAW_EYE__RATE_LIMIT__API_MAX_REQUESTS=1200
# LAW_EYE__RATE_LIMIT__API_WINDOW_SECONDS=60

# ---

# 直接运行 API/Worker（不走 docker-compose）时的可选配置
# AppConfig 通过 LAW_EYE__ 前缀解析（见：crates/law-eye-common/src/config.rs）
LAW_EYE__SERVER__HOST=0.0.0.0
LAW_EYE__SERVER__PORT=3001
# CORS/CSRF Origin allowlist（逗号分隔列表写法）
# LAW_EYE__SERVER__ALLOWED_ORIGINS=http://localhost:8849,http://127.0.0.1:8849

LAW_EYE__DATABASE__URL=postgres://law_eye:your_password@localhost:5435/law_eye
LAW_EYE__DATABASE__MAX_CONNECTIONS=10
LAW_EYE__REDIS__URL=redis://localhost:6380

LAW_EYE__AI__API_KEY=
LAW_EYE__AI__BASE_URL=https://api.openai.com/v1
LAW_EYE__AI__MODEL=gpt-4o-mini
LAW_EYE__AI__EMBEDDING_MODEL=text-embedding-3-small

# 对象存储（S3 / MinIO）
# - enabled=false 时，API 将拒绝 objects 上传/下载相关能力（避免误用）
# - endpoint 示例：MinIO（compose）= http://127.0.0.1:9000
LAW_EYE__OBJECT_STORAGE__ENABLED=false
LAW_EYE__OBJECT_STORAGE__ENDPOINT=
LAW_EYE__OBJECT_STORAGE__REGION=us-east-1
LAW_EYE__OBJECT_STORAGE__BUCKET=
LAW_EYE__OBJECT_STORAGE__ACCESS_KEY_ID=
LAW_EYE__OBJECT_STORAGE__SECRET_ACCESS_KEY=
LAW_EYE__OBJECT_STORAGE__FORCE_PATH_STYLE=true

# [DATA-C04] Purge 补偿删除（软删后异步清理对象存储；失败自动重试）
# - interval=0 可关闭后台 purge loop（仍保留 attempts/error 供人工处理）
LAW_EYE__OBJECT_STORAGE__PURGE_INTERVAL_SECONDS=60
LAW_EYE__OBJECT_STORAGE__PURGE_BATCH_SIZE=50
LAW_EYE__OBJECT_STORAGE__PURGE_GRACE_PERIOD_SECONDS=0
LAW_EYE__OBJECT_STORAGE__PURGE_MAX_ATTEMPTS=20

# Prometheus 指标（/metrics）
# - 非生产环境默认开放（便于本地调试）
# - 生产环境若未设置 token，将返回 404（默认不暴露）
LAW_EYE__METRICS__TOKEN=
