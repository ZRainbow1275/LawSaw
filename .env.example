# Docker Compose 必需环境变量
# ⚠️ 不要在仓库目录（workspace）创建/保存 `.env`：gitignore 不是控制措施。
# 推荐做法：
# - 本地无 DockerHub 运行：直接执行 `scripts/no-dockerhub/start-stack.sh`（默认在用户 state 目录生成 `secrets.env`）
# - 直接使用 compose：用 `docker compose --env-file <外部路径>` 指向本文件的副本（副本放在用户 state 目录）
POSTGRES_PASSWORD=
REDIS_PASSWORD=
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=

# 企业模式（Vault + Gateway + pg_tde）
# - 推荐放到用户 state 目录（而不是仓库目录）
# LAW_EYE_ENTERPRISE_PKI_DIR=${XDG_STATE_HOME:-$HOME/.local/state}/law-eye/enterprise/pki
# LAW_EYE_ENTERPRISE_SECRETS_DIR=${XDG_STATE_HOME:-$HOME/.local/state}/law-eye/enterprise/secrets

# 可选：端口映射（用于避免本机端口冲突）
# POSTGRES_HOST_PORT=5435
# REDIS_HOST_PORT=6380
# API_HOST_PORT=3001
# WEB_HOST_PORT=8849
# MINIO_API_PORT=9000
# MINIO_CONSOLE_PORT=9001
# N8N_HOST_PORT=5678

# AI（OpenAI compatible）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Web Push（浏览器推送）
# - 需配置 VAPID key pair（base64url/base64 编码的原始 key bytes）
# - subject 建议使用 `mailto:` 或 https URL（将写入 VAPID JWT 的 `sub`）
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_SUBJECT=

# n8n workflows（可选）
EMAIL_FROM=noreply@laweye.com
EMAIL_TO=

# 生产模式（启用 secure cookie）
# PRODUCTION=true

# Auth（可选）
# - TTL 仅影响 token 过期时间；生产环境应通过邮件等渠道交付 token（API 不会回传 raw token）
# LAW_EYE__AUTH__PASSWORD_RESET_TTL_SECONDS=3600
# LAW_EYE__AUTH__EMAIL_VERIFICATION_TTL_SECONDS=86400

# Rate limit（可选，按客户端 IP）
# LAW_EYE__RATE_LIMIT__LOGIN_MAX_REQUESTS=5
# LAW_EYE__RATE_LIMIT__LOGIN_WINDOW_SECONDS=900
# LAW_EYE__RATE_LIMIT__REGISTER_MAX_REQUESTS=3
# LAW_EYE__RATE_LIMIT__REGISTER_WINDOW_SECONDS=3600
# LAW_EYE__RATE_LIMIT__PASSWORD_RESET_MAX_REQUESTS=3
# LAW_EYE__RATE_LIMIT__PASSWORD_RESET_WINDOW_SECONDS=3600
# LAW_EYE__RATE_LIMIT__EMAIL_VERIFICATION_MAX_REQUESTS=5
# LAW_EYE__RATE_LIMIT__EMAIL_VERIFICATION_WINDOW_SECONDS=3600
# LAW_EYE__RATE_LIMIT__API_MAX_REQUESTS=1200
# LAW_EYE__RATE_LIMIT__API_WINDOW_SECONDS=60
# Redis key 前缀（最终 key: <prefix>:<scope>:<client_ip>）
# LAW_EYE__RATE_LIMIT__REDIS_PREFIX=law-eye:rate-limit
# Redis 异常时策略：true=fail-open（放行），false=fail-closed（返回 429）
# LAW_EYE__RATE_LIMIT__REDIS_FAIL_OPEN=true

# ---

# 直接运行 API/Worker（不走 docker-compose）时的可选配置
# AppConfig 通过 LAW_EYE__ 前缀解析（见：crates/law-eye-common/src/config.rs）
LAW_EYE__SERVER__HOST=0.0.0.0
LAW_EYE__SERVER__PORT=3001
# CORS/CSRF Origin allowlist（逗号分隔列表写法）
# LAW_EYE__SERVER__ALLOWED_ORIGINS=http://localhost:8849,http://127.0.0.1:8849

# ── Server 高级配置 ──
# LAW_EYE__SERVER__REQUEST_TIMEOUT_MS=30000
# LAW_EYE__SERVER__MAX_BODY_BYTES=10485760

LAW_EYE__DATABASE__URL=postgres://law_eye:your_password@localhost:5435/law_eye
LAW_EYE__DATABASE__MAX_CONNECTIONS=10
# RLS 强制执行（生产环境必须设置）
# - 设置后每个连接执行 SET ROLE law_eye_app，确保 RLS 生效
# - 需要先执行 007_rls_enforcement.sql + 038_auth_compatible_rls.sql 迁移
# - 认证操作（login/register）在无 tenant 上下文时仍可正常工作（见 038 迁移）
LAW_EYE__DATABASE__SESSION_ROLE=law_eye_app
LAW_EYE__REDIS__URL=redis://localhost:6380
LAW_EYE__REDIS__POOL_WAIT_TIMEOUT_MS=2000
LAW_EYE__REDIS__POOL_CREATE_TIMEOUT_MS=2000
LAW_EYE__REDIS__POOL_RECYCLE_TIMEOUT_MS=2000

# Spider HTTP 重试（应对 429/5xx 与暂时性网络抖动）
LAW_EYE__SPIDER__HTTP_MAX_RETRIES=3
LAW_EYE__SPIDER__HTTP_RETRY_BASE_DELAY_MS=300
LAW_EYE__SPIDER__HTTP_RETRY_MAX_DELAY_MS=5000
# 绕过系统代理（Windows 下系统代理可能导致 502）
# LAW_EYE__SPIDER__NO_PROXY=1

# Browserless 动态渲染（headless Chrome，用于 JS 渲染页面）
# - 需要 `docker compose --profile crawler up` 启动 browserless 服务
# - 或指向外部 Browserless 实例
LAW_EYE__BROWSERLESS__URL=http://localhost:3003
LAW_EYE__BROWSERLESS__TOKEN=
LAW_EYE__BROWSERLESS__TIMEOUT_MS=30000
# BROWSERLESS_HOST_PORT=3003
# BROWSERLESS_MAX_CONCURRENT=5

# Worker 推送预览
LAW_EYE__PUSH__PREVIEW_LIMIT=3

# ── Worker 健康检查 ──
# LAW_EYE__WORKER__HEALTH_ENABLED=true
# LAW_EYE__WORKER__HEALTH_HOST=0.0.0.0
# LAW_EYE__WORKER__HEALTH_PORT=3002
# LAW_EYE__WORKER__HEALTH_CHECK_TIMEOUT_MS=2000

# ── 配置热重载 ──
# LAW_EYE__CONFIG_RELOAD__ENABLED=false
# LAW_EYE__CONFIG_RELOAD__INTERVAL_SECONDS=300

# ── 企业安全 ──
# LAW_EYE__ENCRYPTION__FEEDBACKS__ENABLED=false
# LAW_EYE__ENCRYPTION__FEEDBACKS__REQUIRE_IN_PRODUCTION=true
# LAW_EYE__ENCRYPTION__FEEDBACKS__BACKFILL_ON_STARTUP=true
# LAW_EYE__ENCRYPTION__FEEDBACKS__BACKFILL_BATCH_SIZE=100
# LAW_EYE__ENCRYPTION__FEEDBACKS__BACKFILL_MAX_BATCHES=0
# LAW_EYE__SECRETS__VAULT__ENABLED=false
# LAW_EYE__SECURITY__ALLOW_INTERNAL_WEBHOOK_URLS=false

# Logging
RUST_LOG=info

# LawSaw 默认 AI 提供方：SiliconFlow（OpenAI 兼容 chat / embedding + 独立 rerank 端点）
# - 申请 API Key：https://cloud.siliconflow.cn/account/ak
# - API Key 仅放置于 .env.local（已 gitignore），切勿提交。
LAW_EYE__AI__API_KEY=<your-siliconflow-api-key>
LAW_EYE__AI__BASE_URL=https://api.siliconflow.cn/v1
LAW_EYE__AI__MODEL=Qwen/Qwen3-8B
LAW_EYE__AI__EMBEDDING_MODEL=BAAI/bge-m3
# bge-m3 原生维度 1024（迁移 064 已新增 embedding_v2 VECTOR(1024) 列）
LAW_EYE__AI__EMBEDDING_VECTOR_DIM=1024
# strict | pad_or_truncate
# - strict: 维度不匹配直接报错（生产推荐）
# - pad_or_truncate: 自动补零/截断以兼容不同 embedding 模型（本地联调可用）
LAW_EYE__AI__EMBEDDING_DIMENSION_STRATEGY=strict

# Rerank（SiliconFlow 独立端点 /v1/rerank，非 OpenAI 兼容）
LAW_EYE__AI__RERANK_BASE_URL=https://api.siliconflow.cn/v1
LAW_EYE__AI__RERANK_MODEL=BAAI/bge-reranker-v2-m3
# 自由 tier QPS = 12（保守取 12 个并发许可）
LAW_EYE__AI__RERANK_MAX_CONCURRENCY=12
LAW_EYE__AI__RERANK_TIMEOUT_SECONDS=5

# OpenAI 兼容模式（如需切回 OpenAI 官方）：
# LAW_EYE__AI__BASE_URL=https://api.openai.com/v1
# LAW_EYE__AI__MODEL=gpt-4o-mini
# LAW_EYE__AI__EMBEDDING_MODEL=text-embedding-3-small
# LAW_EYE__AI__EMBEDDING_VECTOR_DIM=1536

# MCP Server 访问令牌（必须与客户端 initialize 请求中的 auth_token 一致）
LAW_EYE_MCP_AUTH_TOKEN=

# 对象存储（S3 / MinIO）
# - enabled=false 时，API 将拒绝 objects 上传/下载相关能力（避免误用）
# - endpoint 示例：MinIO（compose）= http://127.0.0.1:9000
LAW_EYE__OBJECT_STORAGE__ENABLED=false
LAW_EYE__OBJECT_STORAGE__ENDPOINT=
LAW_EYE__OBJECT_STORAGE__REGION=us-east-1
LAW_EYE__OBJECT_STORAGE__BUCKET=
LAW_EYE__OBJECT_STORAGE__ACCESS_KEY_ID=
LAW_EYE__OBJECT_STORAGE__SECRET_ACCESS_KEY=
LAW_EYE__OBJECT_STORAGE__FORCE_PATH_STYLE=true
LAW_EYE__OBJECT_STORAGE__SSE_ENABLED=true

# [DATA-C04] Purge 补偿删除（软删后异步清理对象存储；失败自动重试）
# - interval=0 可关闭后台 purge loop（仍保留 attempts/error 供人工处理）
LAW_EYE__OBJECT_STORAGE__PURGE_INTERVAL_SECONDS=60
LAW_EYE__OBJECT_STORAGE__PURGE_BATCH_SIZE=50
LAW_EYE__OBJECT_STORAGE__PURGE_GRACE_PERIOD_SECONDS=0
LAW_EYE__OBJECT_STORAGE__PURGE_MAX_ATTEMPTS=20

# Prometheus 指标（/metrics）
# - 非生产环境默认开放（便于本地调试）
# - 生产环境若未设置 token，将返回 404（默认不暴露）
LAW_EYE__METRICS__TOKEN=
