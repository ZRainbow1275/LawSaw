# Server
LAW_EYE__SERVER__HOST=0.0.0.0
LAW_EYE__SERVER__PORT=3001

# Database
LAW_EYE__DATABASE__URL=postgres://law_eye:law_eye@localhost:5435/law_eye
LAW_EYE__DATABASE__MAX_CONNECTIONS=10
POSTGRES_PASSWORD=law_eye_secret

# Redis
LAW_EYE__REDIS__URL=redis://localhost:6380

# Logging
RUST_LOG=info,law_eye=debug

# OpenAI / LLM
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# Security
JWT_SECRET=change_this_to_a_random_secret_in_production

# Email (for n8n workflows)
EMAIL_FROM=noreply@laweye.com
EMAIL_TO=user@example.com
